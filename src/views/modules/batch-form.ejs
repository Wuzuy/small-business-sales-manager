<div class="page-header">
  <h1>🏭 Novo Lote de Produção</h1>
</div>

<form method="POST" action="/lotes/novo" class="form-card">
  <div class="form-group">
    <label>Descrição do Produto *</label>
    <input type="text" name="description" placeholder="ex: Sacolé de Morango, Dia 26/02" required>
  </div>

  <div class="form-row">
    <div class="form-group">
      <label>Data de Produção *</label>
      <input type="date" name="date" value="<%= new Date().toISOString().split('T')[0] %>" required>
    </div>

    <div class="form-group">
      <label>Quantidade Produzida (un.) *</label>
      <input type="number" name="quantityProduced" step="1" placeholder="0" required>
    </div>
  </div>

  <div class="form-group">
    <label>Modo de Custo *</label>
    <select name="costMode" id="costMode" required>
      <option value="TOTAL" selected>Custo total do lote</option>
      <option value="UNIT">Custo unitário por unidade</option>
    </select>
  </div>

  <div class="form-group">
    <label id="cost-value-label">Custo Total da Produção (R$) *</label>
    <input type="number" name="costValue" id="costValue" step="0.01" placeholder="0.00" required>
  </div>

  <div class="info-box">
    <p id="cost-hint">O custo por unidade será calculado automaticamente.</p>
  </div>

  <div class="form-actions">
    <a href="/lotes" class="btn btn-secondary">← Cancelar</a>
    <button type="submit" class="btn btn-primary">💾 Criar Lote</button>
  </div>
</form>

<style>
.info-box {
  background: var(--color-primary-light);
  border-left: 4px solid var(--color-primary);
  padding: 1rem;
  margin: 1rem 0;
  border-radius: 4px;
  font-size: 0.9rem;
}
</style>

<script>
function updateBatchCostUI() {
  var mode = document.getElementById('costMode').value;
  var label = document.getElementById('cost-value-label');
  var hint = document.getElementById('cost-hint');

  if (mode === 'UNIT') {
    label.textContent = 'Custo Unitário da Produção (R$) *';
    hint.textContent = 'O custo total do lote será calculado automaticamente (custo unitário × quantidade).';
  } else {
    label.textContent = 'Custo Total da Produção (R$) *';
    hint.textContent = 'O custo por unidade será calculado automaticamente.';
  }
}

document.getElementById('costMode').addEventListener('change', updateBatchCostUI);
updateBatchCostUI();
</script>
