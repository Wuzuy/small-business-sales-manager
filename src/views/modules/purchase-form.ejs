<div class="page-header">
  <div>
    <h1>Nova Compra</h1>
    <p>Registrar entrada de produtos no estoque</p>
  </div>
  <a href="/compras" class="btn btn-secondary">← Voltar</a>
</div>

<form method="POST" action="/compras/nova" class="form-card">
  <div class="form-row">
    <div class="form-group">
      <label>Data da Compra *</label>
      <input type="date" name="date" value="<%= new Date().toISOString().split('T')[0] %>" required>
    </div>
    <div class="form-group">
      <label>Fornecedor</label>
      <input type="text" name="supplierName" placeholder="Nome do fornecedor">
    </div>

    <div class="form-group">
      <label>Modo de Custo</label>
      <select name="costMode" id="costMode">
        <option value="UNIT">Custo unitário</option>
        <option value="TOTAL" selected>Custo total do item</option>
      </select>
    </div>
  </div>

  <hr>
  <h3 style="font-size: var(--font-size-sm); font-weight:700; text-transform:uppercase; letter-spacing:.05em; color:var(--text-secondary); margin-bottom:var(--spacing-lg);">Itens da Compra</h3>

  <div class="table-wrapper" style="margin-bottom: var(--spacing-lg);">
    <table>
      <thead>
        <tr>
          <th>Produto</th>
          <th style="width:110px;">Quantidade</th>
          <th style="width:150px;" id="cost-header">Custo Unit. (R$)</th>
          <th style="width:130px;" class="text-right">Subtotal</th>
          <th style="width:50px;"></th>
        </tr>
      </thead>
      <tbody id="purchase-items">
        <tr class="item-row">
          <td>
            <input type="text" class="product-search" placeholder="Buscar produto..." style="margin-bottom:6px;">
            <select name="productIds" required>
              <option value="">Selecione um produto...</option>
              <% products.forEach(p => { %>
                <option value="<%= p.id %>"><%= p.name %></option>
              <% }); %>
            </select>
          </td>
          <td>
            <input type="number" name="quantities" step="1" min="1"
              placeholder="0" required style="width:90px; text-align:center;">
          </td>
          <td>
            <input type="number" step="0.01" min="0" name="costs"
              placeholder="0,00" required style="width:120px;">
          </td>
          <td class="text-right currency" style="font-weight:600;">
            R$ <span class="subtotal">0,00</span>
          </td>
          <td>
            <button type="button" class="btn btn-sm btn-danger remove-item">✕</button>
          </td>
        </tr>
      </tbody>
    </table>
  </div>

  <button type="button" id="add-item" class="btn btn-secondary btn-sm" style="margin-bottom: var(--spacing-xl);">
    + Adicionar Item
  </button>

  <div class="form-actions">
    <button type="submit" class="btn btn-primary btn-lg">💾 Registrar Compra</button>
    <a href="/compras" class="btn btn-secondary">Cancelar</a>
  </div>
</form>

<script>
document.getElementById('add-item').addEventListener('click', function() {
  var tbody = document.getElementById('purchase-items');
  var row = document.querySelector('.item-row').cloneNode(true);
  row.querySelectorAll('input').forEach(function(el) { el.value = ''; });
  row.querySelectorAll('select').forEach(function(el) { el.value = ''; });
  row.querySelector('.subtotal').textContent = '0,00';
  attachRow(row);
  tbody.appendChild(row);
});

function getCostMode() {
  return document.getElementById('costMode').value;
}

function updateCostHeader() {
  var header = document.getElementById('cost-header');
  header.textContent = getCostMode() === 'TOTAL' ? 'Custo Total (R$)' : 'Custo Unit. (R$)';
}

function attachRow(row) {
  setupProductSearch(row);

  function recalc() {
    var qty  = parseInt(row.querySelector('input[name="quantities"]').value, 10) || 0;
    var cost = parseFloat(row.querySelector('input[name="costs"]').value) || 0;
    var subtotal = getCostMode() === 'TOTAL' ? cost : (qty * cost);
    row.querySelector('.subtotal').textContent = subtotal.toFixed(2).replace('.', ',');
  }
  row.querySelector('input[name="quantities"]').addEventListener('input', recalc);
  row.querySelector('input[name="costs"]').addEventListener('input', recalc);
  row.querySelector('.remove-item').addEventListener('click', function() {
    if (document.querySelectorAll('.item-row').length > 1) row.remove();
  });
}

function setupProductSearch(row) {
  var searchInput = row.querySelector('.product-search');
  var select = row.querySelector('select[name="productIds"]');
  if (!searchInput || !select) return;

  if (!select.dataset.allOptions) {
    var allOptions = Array.from(select.options).map(function(opt) {
      return { value: opt.value, text: opt.textContent };
    });
    select.dataset.allOptions = JSON.stringify(allOptions);
  }

  function renderOptions() {
    var term = (searchInput.value || '').toLowerCase().trim();
    var selectedValue = select.value;
    var options = JSON.parse(select.dataset.allOptions || '[]');

    select.innerHTML = '';
    options.forEach(function(opt) {
      if (!opt.value || !term || opt.text.toLowerCase().indexOf(term) !== -1) {
        var optionEl = document.createElement('option');
        optionEl.value = opt.value;
        optionEl.textContent = opt.text;
        select.appendChild(optionEl);
      }
    });

    if (selectedValue) {
      var stillExists = Array.from(select.options).some(function(opt) { return opt.value === selectedValue; });
      select.value = stillExists ? selectedValue : '';
    }
  }

  searchInput.addEventListener('input', renderOptions);
}

attachRow(document.querySelector('.item-row'));
document.getElementById('costMode').addEventListener('change', function() {
  updateCostHeader();
  document.querySelectorAll('.item-row').forEach(function(row) {
    var qty  = parseInt(row.querySelector('input[name="quantities"]').value, 10) || 0;
    var cost = parseFloat(row.querySelector('input[name="costs"]').value) || 0;
    var subtotal = getCostMode() === 'TOTAL' ? cost : (qty * cost);
    row.querySelector('.subtotal').textContent = subtotal.toFixed(2).replace('.', ',');
  });
});
updateCostHeader();
</script>
